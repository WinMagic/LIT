<!DOCTYPE html>
<style>

    .logout-link {
        transition: all 0.2s ease;
    }

        .logout-link:hover {
            color: #dc3545 !important;
            background-color: rgba(220, 53, 69, 0.1);
            border-radius: 4px;
        }


    .user-badge {
        background: linear-gradient(to right, #0d6efd20, #0d6efd10);
        color: #0d6efd;
        font-weight: 600;
        padding: 6px 14px;
        border-radius: 20px;
        border: 1px solid #0d6efd40;
        display: inline-flex;
        align-items: center;
        transition: all 0.2s ease;
    }

        .user-badge:hover {
            background: #0d6efd;
            color: white;
            border-color: #0d6efd;
            cursor: pointer;
        }

</style>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LIT Server</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LIT.Server.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="TodoItem" asp-action="Index">LIT Server</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="user-badge me-3">
                                    <i class="bi bi-person-circle me-1"></i>
                                        Welcome @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark logout-link" asp-area="" asp-controller="Account" asp-action="Logout">Logout</a>
                            </li>

                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 - LIT Server
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
