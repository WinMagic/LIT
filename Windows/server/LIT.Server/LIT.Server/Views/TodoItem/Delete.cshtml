@model LIT.ServerMVC.Data.Models.TodoItem


@{
    ViewData["Title"] = "Delete Task";
}

<div class="container py-5" style="max-width: 600px;">
    <div class="card shadow-sm border-0 p-4">
        <h3 class="fw-bold text-danger mb-3">Delete Task</h3>

        <p class="fs-5">Are you sure you want to delete this task?</p>

        <div class="alert alert-warning">
            <strong>@Model.Title</strong>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-grid">
                <button type="submit" class="btn btn-danger">Delete</button>
            </div>
            <a asp-controller="TodoItem" asp-action="Index" class="btn btn-outline-secondary mt-2">Cancel</a>
        </form>
    </div>
</div>
